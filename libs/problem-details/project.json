{
  "name": "problem-details",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/problem-details/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/problem-details",
        "main": "libs/problem-details/src/index.ts",
        "tsConfig": "libs/problem-details/tsconfig.lib.json",
        "assets": ["libs/problem-details/*.md"]
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "jestConfig": "libs/problem-details/jest.config.cts"
      }
    }
  }
}
